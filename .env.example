# ── New Relic (required) ───────────────────────────────────────────────────────

# Account ID — find it in the NR URL: https://one.newrelic.com/accounts/XXXXXXX
NEW_RELIC_ACCOUNT_ID=YOUR_ACCOUNT_ID

# User API Key (NRAK-...) — NR → Profile → API Keys
NEW_RELIC_API_KEY=NRAK-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── New Relic filters (optional) ──────────────────────────────────────────────

# Browser event type that contains Web Vitals (default: PageViewTiming)
# NR_EVENT_TYPE=PageViewTiming

# Restrict data to one NR Browser application — leave unset for all apps
# NR_APP_NAME=My-Browser-App

# Restrict data to one country (ISO 3166-1 alpha-2) — leave unset for all countries
# NR_COUNTRY_CODE=US

# ── Collection (optional) ──────────────────────────────────────────────────────

# How many days to backfill on first run (default: 30)
# BACKFILL_DAYS=30

# Aggregation window size in hours (default: 6)
# INTERVAL_HOURS=6

# ── HTTP / retry (optional) ───────────────────────────────────────────────────

# REQUEST_TIMEOUT=60
# MAX_RETRIES=3
# RETRY_DELAY=2.0

# ── Corporate proxy / SSL (optional) ─────────────────────────────────────────
#
# If your machine routes traffic through a corporate SSL-inspection proxy:
#
# 1. Disable SSL verification (the proxy replaces the server cert with its own):
#    NR_SSL_VERIFY=false
#    Or trust the corporate CA bundle instead:
#    NR_SSL_VERIFY=/path/to/corporate-ca.pem
#
# 2. Bypass the proxy for NR requests (fixes HTTP 413 — proxy blocks POST):
#    NR_BYPASS_PROXY=true
#
#    Or route NR requests through a specific proxy:
#    NR_HTTPS_PROXY=http://proxy.corp.example.com:8080
#
# NR_SSL_VERIFY=false
# NR_BYPASS_PROXY=true

# ── Dashboard ──────────────────────────────────────────────────────────────────

# Priority URLs pinned to the top of the Page URLs table (comma-separated paths)
# PINNED_URL_PATHS=/,/search,/cart,/checkout

STREAMLIT_PORT=8501

# ── Paths (optional — defaults are inside the project data/ directory) ─────────

# DATA_DIR=/custom/path/data
# DB_PATH=/custom/path/data/web_vitals.db
# LOG_DIR=/custom/path/data/logs
